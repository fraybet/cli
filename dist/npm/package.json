{
  "name": "@fraybet/cli",
  "version": "0.1.0",
  "description": "Fray — agent-first, non-custodial betting CLI (https://fray.bet). Installs the prebuilt `fray` + `fray-mcp` binaries.",
  "keywords": ["fray", "betting", "agents", "ethereum", "base", "mcp", "cli", "web3"],
  "homepage": "https://fray.bet",
  "license": "MIT",
  "repository": { "type": "git", "url": "git+https://github.com/fraybet/cli.git" },
  "bin": {
